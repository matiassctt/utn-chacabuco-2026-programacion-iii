# ============================================================
#  CodeIgniter 4 — .gitignore
# ============================================================

# ─── Entorno y configuración sensible ───────────────────────
.env
.env.*
!.env.example

# ─── Vendor (Composer) ──────────────────────────────────────
/vendor/

# ─── Archivos de escritura generados por CI4 ────────────────
/writable/cache/*
/writable/debugbar/*
/writable/logs/*
/writable/session/*
/writable/uploads/*
/writable/tmp/*

# Mantener la estructura de carpetas en el repo
!writable/cache/.gitkeep
!writable/debugbar/.gitkeep
!writable/logs/.gitkeep
!writable/session/.gitkeep
!writable/uploads/.gitkeep
!writable/tmp/.gitkeep

# ─── Docker ─────────────────────────────────────────────────
docker/mysql/data/

# ─── Node / Frontend ────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
dist/
build/
.parcel-cache/
.vite/

# ─── IDEs y editores ────────────────────────────────────────
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
*.code-workspace
.history/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ─── Sistemas operativos ────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ─── PHP ────────────────────────────────────────────────────
*.log
*.cache
*.pid
*.lock
!composer.lock

# ─── Testing ────────────────────────────────────────────────
/build/
.phpunit.result.cache
.phpunit.cache/
coverage/
.coverage
*.coveragexml
phpunit.xml
!phpunit.xml.dist

# ─── Backups y temporales ───────────────────────────────────
*.bak
*.backup
*.tmp
*.temp
*.old
*.orig
*.rej

# ─── Archivos de base de datos locales ──────────────────────
*.sql
*.sqlite
*.sqlite3
*.db

# ─── Archivos comprimidos ───────────────────────────────────
*.zip
*.tar.gz
*.rar
*.7z